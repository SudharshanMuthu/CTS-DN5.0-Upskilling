<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bootstrap Exercise 6</title>

    <!-- Bootstrap CDN -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

<div class="container mt-5">

    <h1 class="text-center text-primary mb-4">
        Bootstrap Flexbox Utilities
    </h1>

    <!-- Exercise 6.1 -->

    <h2 class="mb-3">
        Responsive Navbar using Flexbox
    </h2>

    <div class="d-flex flex-column flex-md-row bg-dark text-white p-3">

        <div class="me-md-4">
            Community Portal
        </div>

        <div class="me-md-3">
            Home
        </div>

        <div class="me-md-3">
            Events
        </div>

        <div>
            Contact
        </div>

    </div>

    <hr class="my-5">

    <!-- Exercise 6.2 -->

    <h2 class="mb-3">
        Card Layout using Flexbox
    </h2>

    <div class="card p-3">

        <div class="d-flex justify-content-between align-items-center">

            <div>

                <h4>Music Festival</h4>

                <p class="mb-0">
                    Community Event Registration
                </p>

            </div>

            <button class="btn btn-success">
                Register
            </button>

        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
